{
  "name": "@kagent/operator",
  "version": "0.0.0",
  "private": true,
  "description": "Kubernetes control plane — watches Agent + AgentTask + AgentCapability CRDs and materializes pods (Phase 2).",
  "license": "MIT",
  "author": "Chris Knuteson <chris@ctkadvisors.net>",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "start": "tsx src/main.ts",
    "build": "tsc -p .",
    "clean": "rm -rf dist .tsbuildinfo",
    "crd:check": "tsx scripts/check-crd-drift.ts",
    "chart:render-check": "bash scripts/check-runtime-class-render.sh"
  },
  "files": [
    "dist",
    "src",
    "manifests"
  ],
  "dependencies": {
    "@kagent/agent-loop": "workspace:*",
    "@kagent/audit-events": "workspace:*",
    "@kagent/blackboard": "workspace:*",
    "@kagent/cache-controller": "workspace:*",
    "@kagent/capability-types": "workspace:*",
    "@kagent/dto": "workspace:*",
    "@kagent/egress-controller": "workspace:*",
    "@kagent/events": "workspace:*",
    "@kagent/keyrotation-controller": "workspace:*",
    "@kagent/locality-controller": "workspace:*",
    "@kagent/quota-controller": "workspace:*",
    "@kagent/supervision": "workspace:*",
    "@kagent/triggers": "workspace:*",
    "@kagent/versioning-controller": "workspace:*",
    "@kubernetes/client-node": "1.4.0",
    "jose": "6.2.3",
    "nats": "2.29.3"
  },
  "devDependencies": {
    "tsx": "4.21.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
