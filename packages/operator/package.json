{
  "name": "@kagent/operator",
  "version": "0.0.0",
  "private": true,
  "description": "Kubernetes control plane — watches Agent + AgentTask + AgentCapability CRDs and materializes pods (Phase 2).",
  "license": "MIT",
  "author": "Chris Knuteson <chris@ctkadvisors.net>",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "start": "tsx src/main.ts",
    "chart:render-check": "bash scripts/check-runtime-class-render.sh"
  },
  "dependencies": {
    "@kagent/agent-loop": "workspace:*",
    "@kubernetes/client-node": "1.4.0",
    "nats": "2.29.3"
  },
  "devDependencies": {
    "tsx": "4.21.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
