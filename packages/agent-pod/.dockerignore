# SPDX-License-Identifier: MIT
# Build-context exclusions for `docker build -f packages/agent-pod/Dockerfile .`
# (build context is the repo root).

**/node_modules
**/dist
**/coverage
**/.tsbuildinfo
**/.git
**/.gitignore
**/*.test.ts
**/__fixtures__
**/.vitest-cache
**/eslint.config.js
**/vitest.config.ts
**/tsconfig.json
**/tsconfig.eslint.json
docs/
README.md
CLAUDE.md
LICENSE
.github/
.changeset/
.claude/

# Anything related to the operator's chart isn't needed by the
# agent-pod image.
packages/operator/charts/
packages/operator/manifests/
