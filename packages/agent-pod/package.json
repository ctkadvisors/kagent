{
  "name": "@kagent/agent-pod",
  "version": "0.0.0",
  "private": true,
  "description": "Node 22 + tsx agent pod runtime — hosts @kagent/agent-loop, runs one task per Pod, patches AgentTask.status, exports OTel traces. Bun was the v0.1 target but @kubernetes/client-node TLS parity against K3s self-signed CAs forced a revert; revisit in v0.2.",
  "license": "MIT",
  "author": "Chris Knuteson <chris@ctkadvisors.net>",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "start": "node --import tsx/esm src/main.ts",
    "build": "tsc -p .",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@kagent/agent-loop": "workspace:*",
    "@kagent/audit-events": "workspace:*",
    "@kagent/blackboard": "workspace:*",
    "@kagent/capability-types": "workspace:*",
    "@kagent/in-process-tool-provider": "workspace:*",
    "@kagent/openai-compat": "workspace:*",
    "@kagent/trace-sinks": "workspace:*",
    "@kubernetes/client-node": "1.4.0",
    "jose": "6.2.3",
    "nats": "2.29.3"
  },
  "devDependencies": {
    "tsx": "4.21.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
