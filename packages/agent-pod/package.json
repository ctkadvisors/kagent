{
  "name": "@kagent/agent-pod",
  "version": "0.0.0",
  "private": true,
  "description": "Bun-based agent pod runtime — hosts @kagent/agent-loop, subscribes to NATS task subjects, exports OTel traces (Phase 3).",
  "license": "MIT",
  "author": "Chris Knuteson <chris@ctkadvisors.net>",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "start": "node --import tsx/esm src/main.ts"
  },
  "dependencies": {
    "@kagent/agent-loop": "workspace:*",
    "@kagent/in-process-tool-provider": "workspace:*",
    "@kagent/openai-compat": "workspace:*",
    "@kagent/trace-sinks": "workspace:*",
    "@kubernetes/client-node": "1.4.0"
  },
  "devDependencies": {
    "tsx": "4.21.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
