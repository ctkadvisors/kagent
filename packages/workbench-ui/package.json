{
  "name": "@kagent/workbench-ui",
  "version": "0.0.0",
  "private": true,
  "description": "React/Vite single-page app — read-only Workbench frontend. Consumes @kagent/workbench-api over fetch + SSE.",
  "license": "MIT",
  "author": "Chris Knuteson <chris@ctkadvisors.net>",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "build": "tsc -p tsconfig.build.json --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "4.1.4",
    "jsdom": "27.0.1",
    "vite": "6.0.7",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
