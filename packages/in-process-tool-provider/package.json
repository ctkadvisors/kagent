{
  "name": "@kagent/in-process-tool-provider",
  "version": "0.0.0",
  "private": true,
  "description": "In-process ToolProvider — invokes plain JS functions as tools without subprocess overhead.",
  "license": "MIT",
  "author": "Chris Knuteson <chris@ctkadvisors.net>",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "build": "tsc -p .",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@kagent/agent-loop": "workspace:*"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
