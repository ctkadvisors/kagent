{
  "name": "@kagent/dto",
  "version": "0.0.0",
  "private": true,
  "description": "Pure DTO + read-model helpers — maps raw K8s objects (AgentTask, Job, Pod) into UI-friendly summaries any client (Workbench GUI, CLI, webhook) can consume identically.",
  "license": "MIT",
  "author": "Chris Knuteson <chris@ctkadvisors.net>",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./disposition": "./src/disposition.ts",
    "./review-queue": "./src/review-queue.ts"
  },
  "scripts": {
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "build": "tsc -p .",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@kubernetes/client-node": "1.4.0",
    "yaml": "2.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
